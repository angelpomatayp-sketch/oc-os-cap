generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  L
  C
  E
  F
}

enum DocumentType {
  OC
  OS
}

enum DocumentStatus {
  BORRADOR
  PENDIENTE_APROBACION
  APROBADO
  EMITIDO
  ANULADO
}

enum CurrencyCode {
  PEN
  USD
}

model User {
  id           String   @id
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model Provider {
  id                String   @id
  businessName      String
  ruc               String   @unique @db.VarChar(11)
  fiscalAddress     String
  contactName       String   @default("")
  email             String   @default("")
  phone             String   @default("")
  bankName          String   @default("")
  bankAccount       String   @default("")
  bankCci           String   @default("")
  detraccionAccount String   @default("")
  isRetentionAgent  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  orders            Order[]
}

model SystemSetting {
  id                 Int      @id
  companyName        String
  companyRuc         String
  companyAddress     String
  companyContact     String
  companyEmail       String
  companyPhone       String
  companyCell        String
  igvRate            Decimal  @db.Decimal(5, 2)
  retentionRate      Decimal  @db.Decimal(5, 2)
  retentionEnabled   Boolean  @default(true)
  retentionThreshold Decimal  @db.Decimal(10, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Order {
  id              String         @id
  code            String         @unique
  type            DocumentType
  area            Role
  requester       String
  status          DocumentStatus
  currency        CurrencyCode
  workUnit        String         @default("")
  issueDate       DateTime
  subtotalAmount    Decimal        @db.Decimal(12, 2)
  igvAmount         Decimal        @db.Decimal(12, 2)
  retentionAmount   Decimal        @db.Decimal(12, 2)
  payableAmount     Decimal        @db.Decimal(12, 2)
  applyRetention    Boolean        @default(false)
  amountInWords     String
  totalAmount       Decimal        @db.Decimal(12, 2)
  operationType     String         @default("")
  detraccionAmount  Decimal        @db.Decimal(12, 2) @default(0)
  detraccionRate    Decimal        @db.Decimal(5, 2)  @default(0)
  userId          String
  providerId      String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  provider        Provider       @relation(fields: [providerId], references: [id], onDelete: Restrict)
  items           OrderItem[]

  @@index([userId, issueDate])
  @@index([providerId])
}

model OrderItem {
  id          String   @id
  orderId     String
  position    Int
  quantity    Decimal  @db.Decimal(10, 2)
  description String   @db.Text
  unitPrice   Decimal  @db.Decimal(12, 2)
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, position])
}
